# ===========================================
# Our.ca Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ===========================================
# CLERK AUTHENTICATION
# ===========================================
# Get these from: https://dashboard.clerk.com
# 1. Create a new application (or select existing)
# 2. Go to "API Keys" in the left sidebar
# 3. Copy the keys from the "Quick Copy" section

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (customize as needed)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Webhook Secret (for syncing user deletions)
# Get this from: Clerk Dashboard > Webhooks > Your webhook > Signing Secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# SUPABASE DATABASE
# ===========================================
# Get these from: https://supabase.com/dashboard
# 1. Create a new project (or select existing)
# 2. Go to "Settings" > "API" in the left sidebar
# 3. Copy the values from the "Project URL" and "Project API keys" sections

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# Note: SUPABASE_SERVICE_ROLE_KEY should ONLY be used server-side
# It bypasses Row Level Security - never expose to the client

# ===========================================
# RESEND EMAIL
# ===========================================
# Get these from: https://resend.com/api-keys
# 1. Sign up / log in to Resend
# 2. Go to "API Keys" in the left sidebar
# 3. Click "Create API Key"
# 4. Give it a name (e.g., "Our.ca Production")
# 5. Copy the key (it only shows once!)

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your verified sending domain (set up in Resend dashboard under "Domains")
# For testing, you can use: onboarding@resend.dev
RESEND_FROM_EMAIL=noreply@our.ca

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
